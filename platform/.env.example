# ============================================================================
# The Market Brief Daily — environment variables
# Copy to .env.local and fill in. The app runs without these (degraded:
# logged-out / free tier, sample admin data, fallback indicators).
# ============================================================================

# ---- Site ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Supabase (auth + database) ----
# Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by the Stripe webhook and admin reads. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (billing) ----
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for each recurring plan (Products → Pricing)
STRIPE_PRICE_PRO=
STRIPE_PRICE_INSTITUTIONAL=

# ---- FRED (live macro indicators) ----
# https://fred.stlouisfed.org/docs/api/api_key.html — free
FRED_API_KEY=
